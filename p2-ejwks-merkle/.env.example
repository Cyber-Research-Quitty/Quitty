APP_DB_PATH=./keys.db
REDIS_URL=redis://localhost:6379/0

# Root signer algorithm supported by this project
ROOT_SIGNER=ml-dsa-44
ROOT_SIGNER_KEY_PATH=./root_signer_key.json
LOG_SIGNER=ml-dsa-44
LOG_SIGNER_KEY_PATH=./log_signer_key.json

# Required to authorize key import/delete endpoints.
ADMIN_API_KEY=dev-admin-key

# Bloom filter settings (DoS shield)
BLOOM_BITS=1048576
BLOOM_HASHES=7
BLOOM_ENABLED=true


# Copy to .env --> cp .env.example .env
